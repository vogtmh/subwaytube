<Page
    x:Class="subwayTube.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#000000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="#111111" Padding="12,8">
            <TextBlock Text="subwayTube" FontSize="20" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" />
        </Grid>

        <!-- Search bar -->
        <Grid Grid.Row="1" Background="#1a1a1a" Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     PlaceholderText="Search YouTube..."
                     KeyDown="SearchBox_KeyDown"
                     FontSize="16" />

            <Button x:Name="SearchButton"
                    Grid.Column="1"
                    Content="Search"
                    Click="SearchButton_Click"
                    Margin="8,0,0,0" />
        </Grid>

        <!-- Loading indicator -->
        <ProgressRing x:Name="LoadingRing"
                      Grid.Row="2"
                      IsActive="False"
                      Width="50" Height="50"
                      Foreground="White"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Error message -->
        <TextBlock x:Name="ErrorText"
                   Grid.Row="2"
                   Visibility="Collapsed"
                   Foreground="Red"
                   FontSize="14"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="20" />

        <!-- Search results -->
        <ListView x:Name="ResultsList"
                  Grid.Row="2"
                  Background="Transparent"
                  ItemClick="ResultsList_ItemClick"
                  IsItemClickEnabled="True"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Padding="8">
                        <Image Source="{Binding ThumbnailUrl}"
                               Width="160" Height="90"
                               Stretch="UniformToFill" />
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="White"
                                       FontSize="14"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Author}"
                                       Foreground="Gray"
                                       FontSize="12"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Duration}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Video player overlay -->
        <Grid x:Name="PlayerOverlay"
              Grid.RowSpan="3"
              Background="Black"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#111111" Padding="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ClosePlayerButton"
                        Grid.Column="0"
                        Content="Back"
                        Click="ClosePlayerButton_Click"
                        Margin="4" />

                <ComboBox x:Name="QualitySelector"
                          Grid.Column="2"
                          PlaceholderText="Quality"
                          SelectionChanged="QualitySelector_SelectionChanged"
                          MinWidth="120"
                          Margin="4"
                          VerticalAlignment="Center" />
            </Grid>

            <MediaPlayerElement x:Name="VideoPlayer"
                                Grid.Row="1"
                                AreTransportControlsEnabled="True"
                                AutoPlay="True"
                                Stretch="Uniform" />

            <ProgressRing x:Name="PlayerLoadingRing"
                          Grid.Row="1"
                          IsActive="False"
                          Width="50" Height="50"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <StackPanel Grid.Row="2" Background="#111111" Padding="12">
                <TextBlock x:Name="PlayerTitle"
                           Foreground="White"
                           FontSize="16"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="PlayerVideoTitle"
                           Foreground="White"
                           FontSize="14"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="PlayerVideoAuthor"
                           Foreground="Gray"
                           FontSize="13"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Hidden WebView used as JS engine for signature deciphering -->
        <WebView x:Name="JsEngine" Visibility="Collapsed" Width="0" Height="0" />

        <!-- Debug overlay (fullscreen, scrollable) -->
        <Grid x:Name="DebugOverlay"
              Grid.RowSpan="3"
              Background="Black"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Content="Close Debug"
                    Click="CloseDebug_Click"
                    HorizontalAlignment="Left"
                    Margin="8" />

            <ScrollViewer Grid.Row="1" Margin="8">
                <TextBlock x:Name="DebugText"
                           Foreground="#00FF00"
                           FontSize="11"
                           FontFamily="Consolas"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
