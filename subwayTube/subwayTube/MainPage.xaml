<Page
    x:Class="subwayTube.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#000000">

    <Grid>
        <!-- Main content: search + results -->
        <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="#111111" Padding="12,8">
                <TextBlock Text="subwayTube" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" />
            </Grid>

            <!-- Search bar -->
            <Grid Grid.Row="1" Background="#1a1a1a" Padding="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         PlaceholderText="Search YouTube..."
                         KeyDown="SearchBox_KeyDown"
                         FontSize="16"
                         Background="#333333"
                         Foreground="White"
                         BorderBrush="#555555"
                         Padding="10,8" />

                <Button x:Name="SearchButton"
                        Grid.Column="1"
                        Content="&#xE721;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="18"
                        Click="SearchButton_Click"
                        Width="48" Height="40"
                        Margin="8,0,0,0"
                        Background="#333333"
                        Foreground="White" />
            </Grid>

            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingRing"
                          Grid.Row="2"
                          IsActive="False"
                          Width="50" Height="50"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <!-- Error message -->
            <TextBlock x:Name="ErrorText"
                       Grid.Row="2"
                       Visibility="Collapsed"
                       Foreground="#FF4444"
                       FontSize="14"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="20" />

            <!-- Search results -->
            <ListView x:Name="ResultsList"
                      Grid.Row="2"
                      Background="Transparent"
                      ItemClick="ResultsList_ItemClick"
                      IsItemClickEnabled="True"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="#1a1a1a" Padding="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Grid Grid.Column="0" Height="90">
                                <Image Source="{Binding ThumbnailUrl}"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                                <!-- Duration overlay -->
                                <Border Background="#CC000000"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Padding="4,2"
                                        Margin="0,0,4,4"
                                        CornerRadius="2">
                                    <TextBlock Text="{Binding Duration}"
                                               Foreground="White"
                                               FontSize="11" />
                                </Border>
                            </Grid>

                            <!-- Video info -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="White"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Author}"
                                           Foreground="#AAAAAA"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="{Binding ViewCount}"
                                           Foreground="#888888"
                                           FontSize="11"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Video player overlay -->
        <Grid x:Name="PlayerOverlay"
              Background="#000000"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Player top bar with close button -->
            <Grid Grid.Row="0" Background="#111111" Padding="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="ClosePlayerButton"
                        Content="&#xE72B;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="18"
                        Click="ClosePlayerButton_Click"
                        Background="Transparent"
                        Foreground="White"
                        Width="44" Height="44" />
                <TextBlock x:Name="PlayerTitle"
                           Grid.Column="1"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <!-- Media player -->
            <MediaPlayerElement x:Name="VideoPlayer"
                                Grid.Row="1"
                                AreTransportControlsEnabled="True"
                                AutoPlay="True"
                                Stretch="Uniform" />

            <!-- Player loading indicator -->
            <ProgressRing x:Name="PlayerLoadingRing"
                          Grid.Row="1"
                          IsActive="False"
                          Width="50" Height="50"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <!-- Video info below player -->
            <StackPanel Grid.Row="2" Background="#111111" Padding="12">
                <TextBlock x:Name="PlayerVideoTitle"
                           Foreground="White"
                           FontSize="16"
                           TextWrapping="Wrap"
                           MaxLines="3" />
                <TextBlock x:Name="PlayerVideoAuthor"
                           Foreground="#AAAAAA"
                           FontSize="13"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
